@inherits LayoutComponentBase

<div class="layout">
    <header class="header">
        <a href="/" class="logo">🔧 Forge</a>
        <nav class="nav">
            <a href="/repos/new" class="btn-primary">+ New Repo</a>
        </nav>
    </header>
    <main class="content">
