@page "/{Owner}"
@inject IRepositoryService RepositoryService
@using Microsoft.EntityFrameworkCore

<PageTitle>@Owner - Forge</PageTitle>

<div class="repo-header">
    <h1>@Owner</h1>
</div>

<p>Owner parameter: @Owner</p>

@if (repos == null)
{
    <p>Loading...</p>
}
else if (!repos.Any())
{
    <p class="empty-state">No repositories for @Owner</p>
}
else
{
    <p>Found @repos.Count() repos</p>
    @foreach (var repo in repos)
    {
        <div class="card" style="margin-bottom: 0.5rem; padding: 1rem;">
            <a href="/@repo.Owner/@repo.Name">@repo.Name</a>
        </div>
    }
}

@code {
    [Parameter] public string Owner { get; set; } = "";

    private IEnumerable<Repository>? repos;

    protected override async Task OnParametersSetAsync()
    {
        Console.WriteLine($"[OwnerPage] Owner={Owner}");
        repos = await RepositoryService.GetByOwnerAsync(Owner);
        Console.WriteLine($"[OwnerPage] Found {repos?.Count() ?? 0} repos");
    }
}
